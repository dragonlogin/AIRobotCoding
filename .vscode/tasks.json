{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "cmake-build-debug",
      "type": "shell",
      "command": "wsl -d Ubuntu-20.04 -- bash -c 'cd /mnt/e/Code/AIRobotCoding && cmake --build build --parallel'",
      "options": {
        "shell": {
          "executable": "C:\\Windows\\System32\\cmd.exe",
          "args": ["/d", "/c"]
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "cmake-configure-debug",
      "type": "shell",
      "command": "wsl -d Ubuntu-20.04 -- bash -c 'cd /mnt/e/Code/AIRobotCoding && cmake -B build -S . -DCMAKE_BUILD_TYPE=Debug'",
      "options": {
        "shell": {
          "executable": "C:\\Windows\\System32\\cmd.exe",
          "args": ["/d", "/c"]
        }
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
